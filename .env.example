# Authmatic — environment variables
# Copy to .env and fill in. NEVER commit .env.

# ─── Insforge (backend + model gateway) ──────────────────────────────
# For LOCAL DEV: `docker compose -f docker-compose.local.yml up -d` then use
#   INSFORGE_DB_URL=postgres://authmatic:authmatic@localhost:55432/authmatic
# For INSFORGE CLOUD: fill from your project dashboard.
INSFORGE_API_KEY=
INSFORGE_PROJECT_URL=https://<your-project>.insforge.dev
INSFORGE_DB_URL=postgres://authmatic:authmatic@localhost:55432/authmatic
INSFORGE_MODEL=llama-3.1-70b-instruct

# ─── Daytona (code execution sandbox) ────────────────────────────────
DAYTONA_API_KEY=
# Pre-bake this snapshot at preflight — see README.md step 3
DAYTONA_SNAPSHOT_ID=authmatic-v1

# ─── Rtrvr.ai (browser agent) ────────────────────────────────────────
RTRVR_API_KEY=
# cloud | extension — PICK ONE, do not mix mid-demo
RTRVR_MODE=cloud

# ─── Opsera (compliance MCP) ─────────────────────────────────────────
OPSERA_MCP_URL=https://agent.opsera.ai/mcp
OPSERA_TOKEN=

# ─── App config ──────────────────────────────────────────────────────
# When true: short-circuit all sponsor calls and replay from assets/fixtures/
# Useful for offline dry-runs and as conference-WiFi insurance.
DEMO_FIXTURE_MODE=false

# Where the web UI talks to the agent
AGENT_BASE_URL=http://localhost:8000

# Where the agent posts SSE updates from
WEB_BASE_URL=http://localhost:3000

# ─── Stretch sponsors (uncomment if wiring) ──────────────────────────
# NEAR_AI_API_KEY=
# TIGRIS_ACCESS_KEY=
# TIGRIS_SECRET_KEY=
# BRAIN2_WEBHOOK_SECRET=
